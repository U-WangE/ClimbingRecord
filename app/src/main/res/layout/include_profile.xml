<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_profile_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:srcCompat="@drawable/ic_circle_background"
        android:scaleType="center"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <LinearLayout
        android:id="@+id/ll_instagram_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_profile_image"
        >
        <ImageView
            android:id="@+id/iv_instagram_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="18dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_instagram"
            android:layout_gravity="center"
            />

        <TextView
            android:id="@+id/tv_instagram_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style_kcc_chassam_bold_large"
            android:text="@string/hint_link_to_instagram"
            android:layout_gravity="center"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="5dp"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_instagram_set_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="16dp"
            android:adjustViewBounds="true"
            app:srcCompat="@drawable/ic_arrow_right"
            android:layout_gravity="center"
            />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_nickname_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/ll_instagram_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_profile_image"
        >

        <TextView
            android:id="@+id/tv_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style_kcc_chassam_medium_x_small"
            android:text="@string/default_unknown"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_nickname_modify"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_nickname_modify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="8dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_modify"
            android:layout_marginStart="-2dp"
            android:layout_marginBottom="-5dp"
            app:layout_constraintBottom_toTopOf="@id/tv_nickname"
            app:layout_constraintStart_toEndOf="@id/tv_nickname"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>